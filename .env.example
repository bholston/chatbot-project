# Copy this file to .env.local and fill in your values

# Anthropic
ANTHROPIC_API_KEY=sk-ant-api03-...

# ChromaDB — use http://chroma:8000 when running via Docker Compose
CHROMA_URL=http://localhost:8000

# Context: elite | donate | internal
CHATBOT_CONTEXT=elite

# Go High Level CRM
GHL_API_KEY=pit-...
GHL_LOCATION_ID=
GHL_API_VERSION=v2

# Set to false to skip lead capture globally (useful for testing)
# REQUIRE_LEAD_CAPTURE=false

# Protect the ingest endpoint with a secret header (optional)
# INGEST_SECRET=your-secret-here
